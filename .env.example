# NoRisk by FINLAI — Environment-Vorlage
#
# Kopiere diese Datei nach `.env` und fuelle die Werte aus:  cp .env.example .env
# WICHTIG: `.env` ist in .gitignore — niemals echte Secrets committen.
# Dauerhafte Secrets legt die App ueber SecureStorage ab
# (Einstellungen -> API-Schluessel), NICHT in .env.

# --- Ollama (lokales LLM) --------------------------------------------
# Der KI-Assistent laeuft vollstaendig lokal ueber Ollama. Standard reicht meist.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# --- EncryptedDatabase -----------------------------------------------
# Master-Passphrase fuer SQLCipher. NUR fuer lokale Dev-Installationen.
# Produktiv: Schluessel kommt aus SecureStorage / OS-Keystore (fail-closed).
NORISK_DB_PASSPHRASE=

# --- Optionale externe Dienste (alle optional; leer = Funktion aus) ---
# NVD (CVE-Datenbank): hoeheres Rate-Limit fuer CVE-Lookups.
#   Kostenloser Key: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
# VirusTotal (Datei-Hash-Abgleich im Document-Scanner).
#   Kostenloser Key: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=
# Have I Been Pwned (Breach-Check im Passwort-Pruefer).
#   Key: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# --- Logging & Update ------------------------------------------------
NORISK_LOG_LEVEL=INFO
NORISK_LOG_DIR=
NORISK_UPDATE_CHANNEL=stable
